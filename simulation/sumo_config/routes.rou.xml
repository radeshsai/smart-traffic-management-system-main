<?xml version="1.0" encoding="UTF-8"?>
<!--
    routes.rou.xml — SUMO Vehicle Routes
    ======================================
    Defines vehicle types and traffic flows for all 4 directions.
    Vehicles are generated at realistic rates matching density levels.
-->
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

    <!-- ── Vehicle Types ─────────────────────────────────────── -->
    <vType id="car"
           accel="2.6" decel="4.5" sigma="0.5"
           length="4.5" minGap="2.5" maxSpeed="13.89"
           color="0,0,255" vClass="passenger"
           carFollowModel="IDM"/>

    <vType id="motorcycle"
           accel="3.5" decel="5.0" sigma="0.6"
           length="2.2" minGap="1.5" maxSpeed="16.67"
           color="255,165,0" vClass="motorcycle"
           carFollowModel="IDM"/>

    <vType id="bus"
           accel="1.2" decel="3.0" sigma="0.3"
           length="12.0" minGap="3.0" maxSpeed="11.11"
           color="255,0,0" vClass="bus"
           carFollowModel="IDM"/>

    <vType id="truck"
           accel="1.0" decel="3.0" sigma="0.3"
           length="8.0" minGap="3.0" maxSpeed="11.11"
           color="255,0,255" vClass="truck"
           carFollowModel="IDM"/>

    <!-- ── Routes ────────────────────────────────────────────── -->
    <!-- North → South (straight through) -->
    <route id="route_ns" edges="north_in south_out"/>
    <!-- South → North -->
    <route id="route_sn" edges="south_in north_out"/>
    <!-- East → West -->
    <route id="route_ew" edges="east_in west_out"/>
    <!-- West → East -->
    <route id="route_we" edges="west_in east_out"/>

    <!-- ── Traffic Flows ─────────────────────────────────────── -->
    <!-- North direction: LOW density ~8 vehicles in 30s -->
    <flow id="flow_north_car"  type="car"        route="route_ns"
          begin="0"   end="3600" vehsPerHour="240"  departLane="0" departSpeed="max"/>
    <flow id="flow_north_moto" type="motorcycle"  route="route_ns"
          begin="0"   end="3600" vehsPerHour="60"   departLane="0" departSpeed="max"/>

    <!-- South direction: MEDIUM density ~15 vehicles in 30s -->
    <flow id="flow_south_car"  type="car"        route="route_sn"
          begin="0"   end="3600" vehsPerHour="480"  departLane="0" departSpeed="max"/>
    <flow id="flow_south_moto" type="motorcycle"  route="route_sn"
          begin="0"   end="3600" vehsPerHour="120"  departLane="0" departSpeed="max"/>
    <flow id="flow_south_bus"  type="bus"         route="route_sn"
          begin="0"   end="3600" vehsPerHour="60"   departLane="0" departSpeed="max"/>

    <!-- East direction: HIGH density ~25 vehicles in 30s -->
    <flow id="flow_east_car"   type="car"        route="route_ew"
          begin="0"   end="3600" vehsPerHour="720"  departLane="0" departSpeed="max"/>
    <flow id="flow_east_moto"  type="motorcycle"  route="route_ew"
          begin="0"   end="3600" vehsPerHour="180"  departLane="0" departSpeed="max"/>
    <flow id="flow_east_bus"   type="bus"         route="route_ew"
          begin="0"   end="3600" vehsPerHour="60"   departLane="0" departSpeed="max"/>
    <flow id="flow_east_truck" type="truck"        route="route_ew"
          begin="0"   end="3600" vehsPerHour="60"   departLane="0" departSpeed="max"/>

    <!-- West direction: MEDIUM density ~12 vehicles in 30s -->
    <flow id="flow_west_car"   type="car"        route="route_we"
          begin="0"   end="3600" vehsPerHour="360"  departLane="0" departSpeed="max"/>
    <flow id="flow_west_moto"  type="motorcycle"  route="route_we"
          begin="0"   end="3600" vehsPerHour="60"   departLane="0" departSpeed="max"/>
    <flow id="flow_west_truck" type="truck"        route="route_we"
          begin="0"   end="3600" vehsPerHour="60"   departLane="0" departSpeed="max"/>

</routes>
